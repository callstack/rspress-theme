{
  "name": "@callstack/rspress-preset",
  "version": "0.6.1",
  "description": "Callstack preset for Rspress docs",
  "author": "Jakub Romańczyk <jakub.romanczyk@callstack.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "vendor"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/callstack/rspress-theme/tree/main/packages/preset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstack/rspress-theme.git",
    "directory": "packages/preset"
  },
  "keywords": [
    "rspress",
    "theme",
    "preset",
    "callstack",
    "documentation",
    "react",
    "typescript"
  ],
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@callstack/rspress-theme": "workspace:*",
    "@rspress/plugin-sitemap": "^2.0.8",
    "@vercel/analytics": "^2.0.1",
    "rsbuild-plugin-open-graph": "^1.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.8"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.1",
    "@rslib/core": "^0.20.3",
    "@rspress/core": "^2.0.8",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
