{
  "name": "@callstack/rspress-theme",
  "version": "0.6.1",
  "description": "Callstack theme for Rspress docs",
  "author": "Jakub Romańczyk <jakub.romanczyk@callstack.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "require": "./dist/plugin/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "plugin",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/callstack/rspress-theme/tree/main/packages/theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstack/rspress-theme.git",
    "directory": "packages/theme"
  },
  "keywords": [
    "rspress",
    "theme",
    "callstack",
    "documentation",
    "react",
    "typescript"
  ],
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.1",
    "@rsbuild/plugin-image-compress": "^1.3.2",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rsbuild/plugin-sass": "^1.5.1",
    "@rsbuild/plugin-svgr": "^1.3.1",
    "@rslib/core": "^0.20.3",
    "@rspress/core": "^2.0.8",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2"
  }
}
